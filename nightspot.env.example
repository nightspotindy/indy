# Copy this file to `nightspot.env` (which is gitignored) and fill in the
# blanks. Dropped next to app.py, it's loaded automatically on startup — no
# shell sourcing needed. Real environment variables (e.g. a systemd
# Environment= line) always win over what's here.
#
#   cp nightspot.env.example nightspot.env
#   # then edit nightspot.env and paste your Gmail App Password

# --- Email alerts: emailed to you whenever someone uses the service ---------
# For Gmail you must use a 16-character App Password, NOT your account
# password. Create one at: Google Account -> Security -> 2-Step Verification
# -> App passwords. (2-Step Verification must be on first.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nightspot.indy@gmail.com
SMTP_PASS=paste-your-16-char-app-password-here
NOTIFY_FROM=nightspot.indy@gmail.com
NOTIFY_TO=nightspot.indy@gmail.com

# --- Admin dashboard key (change before the installation goes public) ------
ADMIN_KEY=change-me

# --- Camera image rotation (degrees clockwise: 0, 90, 180, or 270) ---------
# Sony liveview/captures come out in sensor orientation. If the live preview
# is sideways, set this and restart. Try 270 first, then 90 or 180.
CAMERA_ROTATE=0
